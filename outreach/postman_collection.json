    {
      "name": "MCP (AI Agents)",
      "item": [
        {
          "name": "MCP Check package",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"method\":\"tools/call\",\"params\":{\"name\":\"check_package\",\"arguments\":{\"ecosystem\":\"npm\",\"package\":\"express\"}}}"
            },
            "url": {
              "raw": "https://depscope.dev/mcp",
              "protocol": "https",
              "host": ["depscope", "dev"],
              "path": ["mcp"]
            },
            "description": "MCP endpoint for AI agents (Claude, GPT, etc.) to check package health"
          }
        }
      ]
    }
  ]

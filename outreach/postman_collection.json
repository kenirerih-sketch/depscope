{
  "info": {
    "name": "DepScope API",
    "description": "Package Intelligence API — Check health, vulnerabilities, and versions for npm, PyPI, and Cargo packages.\n\nBase URL: https://depscope.dev/api\n\nFree, no API key required.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "depscope"
  },
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Check npm package",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://depscope.dev/api/check/npm/express",
              "protocol": "https",
              "host": ["depscope", "dev"],
              "path": ["api", "check", "npm", "express"]
            },
            "description": "Get full health report for an npm package including score, vulnerabilities, maintenance status"
          }
        },
        {
          "name": "Check PyPI package",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://depscope.dev/api/check/pypi/requests",
              "protocol": "https",
              "host": ["depscope", "dev"],
              "path": ["api", "check", "pypi", "requests"]
            }
          }
        },
        {
          "name": "Check Cargo package",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://depscope.dev/api/check/cargo/serde",
              "protocol": "https",
              "host": ["depscope", "dev"],
              "path": ["api", "check", "cargo", "serde"]
            }
          }
        }
      ]
    },
    {
      "name": "Compare",
      "item": [
        {
          "name": "Compare npm packages",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://depscope.dev/api/compare/npm/express,fastify,hono",
              "protocol": "https",
              "host": ["depscope", "dev"],
              "path": ["api", "compare", "npm", "express,fastify,hono"]
            },
            "description": "Compare health scores of multiple packages side by side"
          }
        },
        {
          "name": "Compare PyPI packages",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://depscope.dev/api/compare/pypi/django,flask,fastapi",
              "protocol": "https",
              "host": ["depscope", "dev"],
              "path": ["api", "compare", "pypi", "django,flask,fastapi"]
            }
          }
        }
      ]
    },
    {
      "name": "Bulk Check",
      "item": [
        {
          "name": "Bulk check npm packages",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"packages\":[\"express\",\"lodash\",\"axios\",\"react\",\"next\"]}"
            },
            "url": {
              "raw": "https://depscope.dev/api/bulk/npm",
              "protocol": "https",
              "host": ["depscope", "dev"],
              "path": ["api", "bulk", "npm"]
            },
            "description": "Check up to 50 packages in a single request"
          }
        }
      ]
    },
